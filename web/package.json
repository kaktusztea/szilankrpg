{
  "name": "szilank-karakteralkoto",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate": "python3 ../data/generate_tables.py",
    "prebuild": "python3 ../data/generate_tables.py",
    "build": "tsc -b && vite build",
    "postbuild": "mkdir -p dist/data/tables dist/data/karakter && cp ../data/tables/*.json dist/data/tables/ && cp ../data/rules.json dist/data/ && cp ../data/karakter/*.json dist/data/karakter/",
    "preview": "vite preview"
  },
  "dependencies": {
    "pako": "^2.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/pako": "^2.0.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0"
  }
}
